{
  "name": "request_song_server",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "bin": "dist/index.js",
  "pkg": {
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "bin"
  },
  "scripts": {
    "dev:api": "ts-node src/index.ts",
    "dev:music": "cd qq-music-api && npm run dev",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:music\"",
    "build": "npm run build:music && npm run build:api && npm run copy:music",
    "build:api": "tsc",
    "build:music": "cd qq-music-api && npm run build",
    "start": "node dist/index.js",
    "start:music": "cd qq-music-api && npm run start",
    "start:all": "concurrently \"npm run start\" \"npm run start:music\"",
    "copy:music": "xcopy qq-music-api\\dist dist\\music /E /H /Y"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "pkg": "^5.8.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.2",
    "concurrently": "^10.0.3",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
